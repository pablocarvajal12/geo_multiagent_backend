# ============================================================
#  GeoMultiAgent - Configuration
# ============================================================

# --- Anthropic (required) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Satellite Data Sources (at least one required) ---
# Copernicus / Sentinel Hub
COPERNICUS_USER=your_copernicus_username
COPERNICUS_PASSWORD=your_copernicus_password

# NASA Earthdata (for Landsat, MODIS, etc.)
EARTHDATA_USERNAME=your_earthdata_username
EARTHDATA_PASSWORD=your_earthdata_password

# Microsoft Planetary Computer (free, no credentials needed for public data)
PLANETARY_COMPUTER_SUBSCRIPTION_KEY=

# --- App Settings ---
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# --- Storage ---
DATA_DIR=./data
OUTPUTS_DIR=./outputs
